{
    "name": "harvardchanschool/self-hosted-upstream",
    "type": "project",
    "require": {
		"harvardchanschool/plugin-design-system": "dev-main",
		"harvardchanschool/plugin-social": "dev-master",
		"harvardchanschool/plugin-ui-shortcodes": "dev-main",
		"the-events-calendar/events-calendar-pro": "^7.4.2",
		"rankmath/seo-by-rank-math-pro": "^3.0.80",
		"harvardchanschool/hsph-wordpress-toolkit": "dev-main"
	},
	"repositories": [
		{
			"type": "vcs",
			"url": "https://github.com/HarvardChanSchool/hsph-wordpress-toolkit"
		},
		{
			"type": "vcs",
			"url": "https://github.com/HarvardChanSchool/plugin-design-system"
		},
		{
			"type": "vcs",
			"url": "https://github.com/HarvardChanSchool/plugin-social"
		},
		{
			"type": "vcs",
			"url": "https://github.com/HarvardChanSchool/plugin-ui-shortcodes"
		},
		{
			"type": "package",
			"package": {
				"name": "the-events-calendar/events-calendar-pro",
				"version": "7.4.2",
				"type": "wordpress-plugin",
				"dist": {
					"url": "https://evnt.is/fetch-ecp?key=a0fb1ee00ac1590ec344fecde11be9fd2b4710fd&version=7.4.2",
					"type": "zip"
				}
			}
		},
		{
			"type": "package",
			"package": {
					"name": "rankmath/seo-by-rank-math-pro",
					"type": "wordpress-plugin",
					"version": "3.0.80",
						"dist": {
							"type": "zip",
							"url": "https://rankmath.com/download/510590/?username=deane&api_key=bad0233c27f41b4aa64560a2254ef85f"
					}
			}
		}
	],
	"extra": {
		"installer-paths": {
			"mu-plugins/{$name}": [
				"type:wordpress-muplugin"
			]
		}
	},
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
